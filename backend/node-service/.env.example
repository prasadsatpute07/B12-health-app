# ─────────────────────────────────────────────
#  B12 Node Service — Environment Configuration
# ─────────────────────────────────────────────

# Server
NODE_ENV=development
NODE_PORT=3000

# PostgreSQL
DATABASE_URL=postgresql://b12user:b12pass@localhost:5432/b12db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=b12db
DB_USER=b12user
DB_PASSWORD=b12pass

# JWT
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=7d

# FastAPI Scoring Service
FASTAPI_URL=http://localhost:8000

# MongoDB (optional — set ENABLE_MONGODB=true to activate)
ENABLE_MONGODB=false
MONGODB_URL=mongodb://localhost:27017/b12db

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
