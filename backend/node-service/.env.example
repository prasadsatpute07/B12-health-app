# ═══════════════════════════════════════════════════════════════
#  B12 Node Service — Environment Configuration
#
#  SECURITY RULES:
#   1. NEVER commit a real .env file to git (already in .gitignore)
#   2. Generate JWT_SECRET with:
#       node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   3. In production, use a secrets manager (AWS Secrets Manager, HashiCorp Vault)
# ═══════════════════════════════════════════════════════════════

# ── Server ───────────────────────────────────────────────────
NODE_ENV=development
NODE_PORT=3000

# ── PostgreSQL ───────────────────────────────────────────────
DATABASE_URL=postgresql://b12user:b12pass@localhost:5432/b12db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=b12db
DB_USER=b12user
DB_PASSWORD=b12pass

# ── JWT ──────────────────────────────────────────────────────
# REQUIRED: Must be at least 32 random characters.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=REPLACE-WITH-OUTPUT-OF-ABOVE-COMMAND-MINIMUM-32-CHARS
JWT_EXPIRES_IN=7d

# JWT claims — used to prevent token reuse across services
# Keep these consistent between server.js and auth middleware
JWT_ISSUER=b12-health
JWT_AUDIENCE=b12-app

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Development: leave empty to allow all, or set to your Expo URL
# Production: set to your exact app origin (NO wildcards)
# Example: exp://192.168.1.100:8081,https://yourdomain.com
ALLOWED_ORIGINS=

# ── Brute-Force Protection ───────────────────────────────────
# Maximum failed login attempts before account is locked
MAX_LOGIN_ATTEMPTS=5
# How long (minutes) to look back when counting failures
ACCOUNT_LOCKOUT_MINUTES=15

# ── Rate Limiting ────────────────────────────────────────────
# General API rate limit (applied to all /api/* routes)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
# Auth routes use MAX_LOGIN_ATTEMPTS/ACCOUNT_LOCKOUT_MINUTES (stricter)

# ── FastAPI Scoring Service ──────────────────────────────────
FASTAPI_URL=http://localhost:8000

# ── MongoDB (optional) ──────────────────────────────────────
ENABLE_MONGODB=false
MONGODB_URL=mongodb://localhost:27017/b12db

# ── Logging ─────────────────────────────────────────────────
# Log levels: error | warn | info | debug
LOG_LEVEL=info
